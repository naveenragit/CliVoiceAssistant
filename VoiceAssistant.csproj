<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>VoiceAssistant</AssemblyName>
    <RootNamespace>VoiceAssistant</RootNamespace>

  </PropertyGroup>

  <ItemGroup>
    <!-- Audio I/O -->
    <PackageReference Include="NAudio" Version="2.2.1" />
    <!-- JSON parsing for Realtime API events -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <!-- Azure AD interactive browser login -->
    <PackageReference Include="Azure.Identity" Version="1.13.2" />
    <PackageReference Include="System.Management" Version="8.0.0" />
    <!-- Windows built-in TTS for system/tool message readback -->
    <PackageReference Include="System.Speech" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
